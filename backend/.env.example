# Backend-specific environment variables example
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/afribiz

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend
FRONTEND_URL=http://localhost:3000

# Email Configuration (Using Mailtrap for development)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-mailtrap-username
SMTP_PASS=your-mailtrap-password
SMTP_FROM=noreply@afribiz.com
SMTP_FROM_NAME=AfriBiz

# Security - Login Attempts & Lockout
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_TIME_MS=900000

# OTP Configuration
OTP_LENGTH=6
OTP_EXPIRES_IN_MINUTES=10
OTP_MAX_ATTEMPTS=3

# Email Verification & Password Reset
EMAIL_VERIFICATION_EXPIRES_IN_HOURS=24
PASSWORD_RESET_EXPIRES_IN_HOURS=1

# Bcrypt Configuration
BCRYPT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# CORS - Allowed Origins
ALLOWED_ORIGINS=http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Sentry
SENTRY_DSN=
