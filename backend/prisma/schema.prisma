// ============================================
// ADMIN RBAC (Part 13)
// ============================================

enum AdminPermissionAction {
  READ
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  SUSPEND
  BAN
  EXPORT
  CONFIGURE
}

model AdminRole {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  permissions AdminRolePermission[]
  admins      AdminRoleAssignment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminPermission {
  id           String   @id @default(uuid())
  resource     String
  action       AdminPermissionAction
  description  String?
  roles        AdminRolePermission[]
  createdAt    DateTime @default(now())

  @@unique([resource, action])
  @@index([resource])
}

model AdminRolePermission {
  roleId       String
  role         AdminRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   AdminPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())

  @@id([roleId, permissionId])
}

model AdminRoleAssignment {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// ============================================
// AUTOMATION RULES (Part 14)
// ============================================

enum AutomationTrigger {
  STOCK_LOW
  STOCK_OUT
  STOCK_BACK_IN
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  PAYMENT_REFUNDED
  ORDER_PLACED
  ORDER_CONFIRMED
  ORDER_CANCELLED
  BOOKING_MADE
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  REVIEW_PUBLISHED
  NEW_CLIENT
  CLIENT_INACTIVE
  SUBSCRIPTION_EXPIRING
  SUBSCRIPTION_EXPIRED
  MODULE_INSTALLED
  MODULE_UNINSTALLED
  SCORE_CHANGED
  BADGE_EARNED
  DEBT_OVERDUE
  DISPUTE_OPENED
  AD_COMPLETED
  EVENT_SCHEDULED
  CUSTOM_WEBHOOK
}

enum AutomationActionType {
  SEND_NOTIFICATION
  SEND_EMAIL
  SEND_SMS
  SEND_WHATSAPP
  UPDATE_STATUS
  APPLY_DISCOUNT
  ASSIGN_TAG
  CREATE_TASK
  UPDATE_SCORE
  BLOCK_USER
  SUSPEND_BUSINESS
  CALL_WEBHOOK
  LOG_EVENT
}

enum AutomationStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

model AutomationRule {
  id          String             @id @default(uuid())
  name        String
  description String?
  trigger     AutomationTrigger
  triggerConfig Json?            @default("{}")
  conditions  Json               @default("[]")
  actionType  AutomationActionType
  actionConfig Json
  cooldownMinutes Int?           @default(0)
  status      AutomationStatus   @default(ACTIVE)
  executionCount Int             @default(0)
  lastExecutedAt DateTime?
  createdBy   String?
  executionLogs AutomationExecutionLog[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([trigger])
  @@index([status])
  @@index([trigger, status])
}

model AutomationExecutionLog {
  id          String    @id @default(uuid())
  ruleId      String
  rule        AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  trigger     AutomationTrigger
  triggerData Json?
  result      String    @default("SUCCESS")
  error       String?
  executedAt  DateTime  @default(now())

  @@index([ruleId])
  @@index([executedAt])
  @@index([result])
}

