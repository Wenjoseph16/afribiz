  sortOrder   Int               @default(0)
  isActive    Boolean           @default(true)
  services    Service[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  @@unique([businessId, slug])
  @@index([businessId])
  @@index([parentId])
}

model ServiceEmployee {
  id        String   @id @default(uuid())
