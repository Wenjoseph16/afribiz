// ============================================
// MEDIA MODERATION (Part 19)
// ============================================

enum MediaContentType {
  STORY
  SHORT
  LIVE
  OFFER_FLASH
  AD_CREATIVE
  PRODUCT_IMAGE
  SERVICE_IMAGE
  PORTFOLIO_MEDIA
  BUSINESS_PHOTO
  REVIEW_IMAGE
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

model MediaModerationItem {
  id              String           @id @default(uuid())
  contentType     MediaContentType
  contentId       String
  reportedById    String?
  reportedBy      User?            @relation("ModerationReporter", fields: [reportedById], references: [id], onDelete: SetNull)
  reason          String?
  description     String?
  status          ModerationStatus @default(PENDING)
  reviewedById    String?
  reviewedBy      User?            @relation("ModerationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  resolution      String?
  actionTaken     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([contentType])
  @@index([status])
  @@index([contentType, status])
  @@index([reportedById])
  @@index([reviewedById])
}

// ============================================
// COMMISSION CONFIGURATION (Part 20)
// ============================================

model CommissionConfig {
  id            String  @id @default(uuid())
  key           String  @unique
  label         String
  description   String?
  rate          Float   @default(0.10)
  scope         String  @default("global")
  scopeValue    String?
  minFee        Decimal? @db.Decimal(12, 2)
  maxFee        Decimal? @db.Decimal(12, 2)
  currency      String  @default("FCFA")
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([key])
  @@index([scope])
  @@index([isActive])
}

// ============================================
// USER WARNINGS (Part 21)
// ============================================

model UserWarning {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("WarnedUser", fields: [userId], references: [id], onDelete: Cascade)
  issuedById  String
  issuedBy    User     @relation("WarningIssuer", fields: [issuedById], references: [id], onDelete: Cascade)
  reason      String
  description String?
  action      String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([issuedById])
}
