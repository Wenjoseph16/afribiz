  createdAt DateTime @default(now())

  @@index([shortId])
  @@index([createdAt])
}

model ShortView {
  id        String   @id @default(uuid())
  shortId   String
  short     Short    @relation(fields: [shortId], references: [id], onDelete: Cascade)
  userId    String?
  visitorId String?
  createdAt DateTime @default(now())

  @@unique([shortId, userId])
  @@index([shortId])
  @@index([userId])
}

model ShortSave {
  id        String   @id @default(uuid())
  shortId   String
  short     Short    @relation(fields: [shortId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([shortId, userId])
  @@index([shortId])
  @@index([userId])
}

// ============================================
// LIVE COMMERCE MODELS (Phase 2 — Lives Commerciaux)
// ============================================

enum LiveStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model Live {
  id              String     @id @default(uuid())
  businessId      String
  business        Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  coverImage      String?
  streamUrl       String?
  streamKey       String?
  status          LiveStatus @default(SCHEDULED)
  hasEscrow       Boolean    @default(false)
  scheduledAt     DateTime?
  startedAt       DateTime?
  endedAt         DateTime?
  viewerCount     Int        @default(0)
  maxViewers      Int?
  viewerCountPeak Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  products     LiveProduct[]
  participants LiveParticipant[]
  chats        LiveChat[]
  reactions    LiveReaction[]

  @@index([businessId])
  @@index([status])
  @@index([createdAt])
}

model LiveProduct {
  id              String  @id @default(uuid())
  liveId          String
  live            Live    @relation(fields: [liveId], references: [id], onDelete: Cascade)
  productId       String?
  name            String
  description     String?
  price           Decimal @db.Decimal(12, 2)
  currency        String  @default("FCFA")
  image           String?
  stock           Int     @default(0)
  remainingStock  Int     @default(0)
  isActive        Boolean @default(true)
  sortOrder       Int     @default(0)
  createdAt       DateTime @default(now())

  @@index([liveId])
}

model LiveParticipant {
  id        String    @id @default(uuid())
  liveId    String
  live      Live      @relation(fields: [liveId], references: [id], onDelete: Cascade)
  userId    String?
  userName  String?
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?
  isActive  Boolean   @default(true)

  @@index([liveId])
  @@index([userId])
}

model LiveChat {
  id        String   @id @default(uuid())
  liveId    String
  live      Live     @relation(fields: [liveId], references: [id], onDelete: Cascade)
  userId    String?
  userName  String   @default("Anonyme")
  message   String
  createdAt DateTime @default(now())

  @@index([liveId])
  @@index([createdAt])
}

model LiveReaction {
  id        String   @id @default(uuid())
  liveId    String
  live      Live     @relation(fields: [liveId], references: [id], onDelete: Cascade)
  userId    String?
  emoji     String   @default("❤️")
  createdAt DateTime @default(now())

  @@index([liveId])
}

// ============================================
// NOTIFICATION MODELS
// ============================================

model Notification {
  id          String                 @id @default(uuid())
  userId      String
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  description String?
  link        String?
  metadata    Json?
  read        Boolean                @default(false)
  readAt      DateTime?
  deliveries  NotificationDelivery[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([userId])
  @@index([userId, read])
  @@index([type])
  @@index([createdAt])
}

model NotificationDelivery {
  id             String              @id @default(uuid())
  notificationId String
  notification   Notification        @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel        NotificationChannel
  status         String              @default("pending")
  sentAt         DateTime?
  errorMessage   String?
  createdAt      DateTime            @default(now())

  @@index([notificationId])
  @@index([channel, status])
}

model NotificationPreference {
  id        String              @id @default(uuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([userId, type, channel])
  @@index([userId])
}

model BusinessNotificationTemplate {
  id              String           @id @default(uuid())
  businessId      String
  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type            NotificationType
  customTitle     String
  customDescription String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([businessId, type])
  @@index([businessId])
  @@index([businessId, isActive])
}

